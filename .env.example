# AWS Configuration
AWS_PROFILE=amc_dev
AWS_DIRECTORY_PATH=~/.aws

# Docker Compose Versions
TEMPORAL_VERSION=1.29.2
TEMPORAL_UI_VERSION=2.44.1
TEMPORAL_ADMINTOOLS_VERSION=1.29.4
POSTGRESQL_VERSION=17

# Convoy API Database Configuration
DATABASE_URL=postgresql+asyncpg://convoy:convoy@localhost:5433/convoy
DATABASE_ECHO=false

# Temporal Configuration
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=convoy-tasks

# Batch Processing Configuration
BATCH_SIZE_THRESHOLD=100
BATCH_CHECK_INTERVAL_SECONDS=30

# Callback Configuration
CALLBACK_MAX_RETRIES=5
CALLBACK_HTTP_TIMEOUT_SECONDS=30

# Result Cleanup Configuration
RESULT_RETENTION_DAYS=30
CLEANUP_BATCH_SIZE=1000

# AWS Bedrock Configuration
AWS_REGION=us-east-1
BEDROCK_S3_BUCKET=your-bedrock-batch-bucket
BEDROCK_ROLE_ARN=arn:aws:iam::123456789012:role/BedrockBatchRole
BEDROCK_S3_INPUT_PREFIX=batch-inputs
BEDROCK_S3_OUTPUT_PREFIX=batch-outputs

# E2E Test Configuration
# API_BASE_URL is used by E2E tests to target different environments
# For local Docker: http://convoy-api:8000
# For local dev: http://localhost:8000
API_BASE_URL=http://convoy-api:8000

# Mock callback server URL for batch flow tests
# For local Docker: http://mock-callback:8001
# For local dev: http://localhost:8001
CALLBACK_SERVER_URL=http://mock-callback:8001
