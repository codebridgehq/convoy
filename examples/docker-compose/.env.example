# Convoy Docker Compose Example - Environment Variables
# Copy this file to .env and configure as needed

# =============================================================================
# CONVOY VERSION
# =============================================================================
# Uncomment to pin to a specific version (recommended for production)
# We recommend using the same version for both API and Worker
# CONVOY_VERSION=latest

# =============================================================================
# TEMPORAL VERSIONS
# =============================================================================
TEMPORAL_VERSION=1.29.2
TEMPORAL_UI_VERSION=2.44.1
TEMPORAL_ADMINTOOLS_VERSION=1.29.4

# =============================================================================
# DATABASE VERSION
# =============================================================================
POSTGRESQL_VERSION=17

# =============================================================================
# CONVOY CONFIGURATION
# =============================================================================
# Batch Processing
BATCH_SIZE_THRESHOLD=100
BATCH_TIME_THRESHOLD_SECONDS=3600
BATCH_CHECK_INTERVAL_SECONDS=30

# Result Cleanup
RESULT_RETENTION_DAYS=30

# Callback Configuration
CALLBACK_MAX_RETRIES=5
CALLBACK_HTTP_TIMEOUT_SECONDS=30

# =============================================================================
# TEMPORAL CONFIGURATION
# =============================================================================
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=convoy-tasks

# =============================================================================
# AWS CONFIGURATION (Required for Bedrock Provider)
# =============================================================================
# Not required if using Anthropic provider or other non-AWS providers
# Can also be configured via:
#   - IAM roles (when running on ECS/EKS)
#   - Environment variables (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
#   - OIDC (AWS_WEB_IDENTITY_TOKEN_FILE)

# Path to AWS credentials directory (mounted into container)
AWS_DIRECTORY_PATH=~/.aws

# AWS Profile to use (from ~/.aws/credentials)
AWS_PROFILE=default

# AWS Region for Bedrock
AWS_REGION=us-east-1

# S3 bucket for Bedrock batch inputs/outputs
BEDROCK_S3_BUCKET=your-bedrock-batch-bucket

# IAM role ARN for Bedrock batch processing
BEDROCK_ROLE_ARN=arn:aws:iam::123456789012:role/BedrockBatchRole

# S3 prefixes for batch data
BEDROCK_S3_INPUT_PREFIX=batch-inputs
BEDROCK_S3_OUTPUT_PREFIX=batch-outputs
